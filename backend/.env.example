# Firebase (backend uses serviceAccountKey.json OR this env var)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Frontend URL(s) for CORS - comma-separated for multiple
FRONTEND_URL=http://localhost:3000

# Cloudflare R2 Storage (for image uploads)
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=cointalk-images
R2_PUBLIC_URL=https://pub-yourid.r2.dev

# Server config
PORT=5001
NODE_ENV=development
